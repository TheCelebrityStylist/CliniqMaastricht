# Built-in /admin login
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Permanent admin data storage on Vercel Postgres / Neon.
# Strongly recommended in production so events, pages, FAQs, SEO, settings and leads persist.
POSTGRES_URL=

# Enables direct photo uploads in /admin/media with Vercel Blob.
# If omitted, admins can still paste already-hosted Cliniq image URLs.
BLOB_READ_WRITE_TOKEN=

# Optional email notifications for inquiry forms
RESEND_API_KEY=
FORM_FROM_EMAIL="Cliniq Website <website@cliniqmaastricht.nl>"
FORM_TO_EMAIL=contact@cafecliniq.com

# Analytics / search verification
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# CSV export protection for /api/leads/export
LEADS_EXPORT_TOKEN=

# Google Sheets agenda sync
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_EVENTS_SHEET_NAME=Events
GOOGLE_EVENTS_SHEET_URL=

# Google Drive photo sync
GOOGLE_DRIVE_HOMEPAGE_FOLDER_ID=
GOOGLE_DRIVE_UITGAAN_FOLDER_ID=
GOOGLE_DRIVE_WORKSHOP_FOLDER_ID=
GOOGLE_DRIVE_EVENT_SPACE_FOLDER_ID=
GOOGLE_DRIVE_CONTACT_FOLDER_ID=
GOOGLE_DRIVE_ALBUMS_ROOT_FOLDER_ID=
GOOGLE_DRIVE_ROOT_URL=
