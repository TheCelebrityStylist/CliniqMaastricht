# Built-in /admin login
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Permanent admin data storage on Vercel Postgres / Neon.
# Production requires Postgres: POSTGRES_URL is used first, DATABASE_URL is supported as fallback.
POSTGRES_URL=
DATABASE_URL=

# Enables direct photo uploads in /admin/media with Vercel Blob.
# If omitted, admins can still paste already-hosted Cliniq image URLs.
BLOB_READ_WRITE_TOKEN=

# Optional email notifications for inquiry forms
RESEND_API_KEY=
FORM_FROM_EMAIL="Cliniq Website <website@cliniqmaastricht.nl>"
FORM_TO_EMAIL=contact@cafecliniq.com

# Analytics / search verification
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# CSV export protection for /api/leads/export
LEADS_EXPORT_TOKEN=
